{
  "name": "@idlekitjs/react",
  "version": "0.1.2",
  "description": "React bindings for @idlekitjs engines: provider and hooks over core state and events.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/idlekitjs/idlekit.git",
    "directory": "packages/react"
  },
  "homepage": "https://idlekitjs.github.io/packages/react",
  "bugs": {
    "url": "https://github.com/idlekitjs/idlekit/issues"
  },
  "keywords": [
    "idlekit",
    "incremental-game",
    "react",
    "hooks"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@idlekitjs/core": "workspace:^",
    "use-sync-external-store": "^1.5.0"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.0",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "@types/use-sync-external-store": "1.5.0",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  }
}
