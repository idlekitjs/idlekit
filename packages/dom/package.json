{
  "name": "@idlekitjs/dom",
  "version": "0.1.1",
  "description": "DOM renderer and declarative bindings for @idlekitjs games (bindText, bindClass, ...).",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./bind-each": {
      "types": "./dist/bind-each/index.d.ts",
      "import": "./dist/bind-each/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/idlekitjs/idlekit.git",
    "directory": "packages/dom"
  },
  "homepage": "https://github.com/idlekitjs/idlekit/tree/main/packages/dom#readme",
  "bugs": {
    "url": "https://github.com/idlekitjs/idlekit/issues"
  },
  "keywords": [
    "idlekit",
    "incremental-game",
    "dom",
    "renderer"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@idlekitjs/core": "workspace:^",
    "@idlekitjs/types": "workspace:^",
    "@idlekitjs/utils": "workspace:^"
  }
}
