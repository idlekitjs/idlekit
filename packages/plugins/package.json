{
  "name": "@idlekitjs/plugins",
  "version": "0.1.3",
  "description": "Platform-agnostic engine policies for @idlekitjs (autosave, offline progress).",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./autosave": {
      "types": "./dist/autosave/index.d.ts",
      "import": "./dist/autosave/index.js"
    },
    "./offline-progress": {
      "types": "./dist/offline-progress/index.d.ts",
      "import": "./dist/offline-progress/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/idlekitjs/idlekit.git",
    "directory": "packages/plugins"
  },
  "homepage": "https://idlekitjs.github.io/packages/plugins",
  "bugs": {
    "url": "https://github.com/idlekitjs/idlekit/issues"
  },
  "keywords": [
    "idlekit",
    "incremental-game",
    "plugins",
    "autosave"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@idlekitjs/core": "workspace:^",
    "@idlekitjs/types": "workspace:^"
  },
  "devDependencies": {
    "@idlekitjs/mechanics": "workspace:^",
    "@idlekitjs/storage": "workspace:^"
  }
}
