{
  "name": "@idlekitjs/browser",
  "version": "0.1.0",
  "description": "Browser runtime bridges connecting browser APIs to @idlekitjs engine contracts (page lifecycle, rAF frame scheduler, screen helpers).",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./page-lifecycle": {
      "types": "./dist/page-lifecycle/index.d.ts",
      "import": "./dist/page-lifecycle/index.js"
    },
    "./raf-scheduler": {
      "types": "./dist/raf-scheduler/index.d.ts",
      "import": "./dist/raf-scheduler/index.js"
    },
    "./screen": {
      "types": "./dist/screen/index.d.ts",
      "import": "./dist/screen/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/idlekitjs/idlekit.git",
    "directory": "packages/browser"
  },
  "homepage": "https://github.com/idlekitjs/idlekit/tree/main/packages/browser#readme",
  "bugs": {
    "url": "https://github.com/idlekitjs/idlekit/issues"
  },
  "keywords": [
    "idlekit",
    "incremental-game",
    "browser",
    "runtime"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@idlekitjs/core": "workspace:^",
    "@idlekitjs/types": "workspace:^",
    "@idlekitjs/utils": "workspace:^"
  }
}
