{
  "name": "idlekit",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "IdleKit package workspace for reusable incremental game tooling.",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" build",
    "build:public": "pnpm --filter @idlekitjs/types --filter @idlekitjs/utils --filter @idlekitjs/core --filter @idlekitjs/economy --filter @idlekitjs/storage --filter @idlekitjs/dom --filter @idlekitjs/browser --filter @idlekitjs/mechanics --filter @idlekitjs/plugins build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "check:headless-core": "node scripts/check-headless-core.mjs",
    "format": "prettier --write .",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build:public && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "2.29.7",
    "@eslint/js": "9.39.1",
    "@types/node": "24.10.1",
    "eslint": "9.39.1",
    "eslint-config-prettier": "10.1.8",
    "happy-dom": "20.0.10",
    "prettier": "3.6.2",
    "tsup": "8.5.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.46.4",
    "vitest": "3.2.4"
  }
}
